{
  "id": 453520,
  "type": "webhook",
  "name": "MDH - Payment Terms (CIB)",
  "url": "https://cib.rossum.app/api/v1/hooks/453520",
  "description": "Enhance the extracted data with details from your master records.",
  "settings": {
    "configurations": [
      {
        "name": "Payment Terms",
        "source": {
          "dataset": "payment_terms_test",
          "queries": [
            {
              "aggregate": [
                {
                  "$match": {
                    "type": "DaysAfterNetPaymentTerm",
                    "active": true,
                    "days-for-net-payment": "{terms_calculated}",
                    "days-for-discount-payment": {
                      "$in": [
                        0,
                        null
                      ]
                    }
                  }
                },
                {
                  "$project": {
                    "id": 1,
                    "code": 1,
                    "days-for-net-payment": 1
                  }
                }
              ]
            },
            {
              "aggregate": [
                {
                  "$match": {
                    "type": "DaysAfterNetPaymentTerm",
                    "active": true,
                    "days-for-discount-payment": null
                  }
                },
                {
                  "$project": {
                    "id": 1,
                    "code": 1,
                    "days-for-net-payment": 1
                  }
                }
              ]
            }
          ]
        },
        "default": {
          "label": "---",
          "value": ""
        },
        "mapping": {
          "label_keys": [
            "code"
          ],
          "dataset_key": "id",
          "target_schema_id": "payment_terms_match"
        },
        "result_actions": {
          "no_match_found": {
            "select": "default"
          },
          "one_match_found": {
            "select": "best_match"
          },
          "multiple_matches_found": {
            "select": "default"
          }
        },
        "additional_mappings": [
          {
            "dataset_key": "days-for-net-payment",
            "target_schema_id": "payment_terms_days_match"
          },
          {
            "dataset_key": "code",
            "target_schema_id": "payment_terms_code_match"
          }
        ]
      },
      {
        "name": "Early Payment Discount Terms",
        "source": {
          "dataset": "payment_terms_test",
          "queries": [
            {
              "aggregate": [
                {
                  "$match": {
                    "type": "DaysAfterNetPaymentTerm",
                    "active": true,
                    "discount-rate": "{epd_rate}",
                    "days-for-discount-payment": "{epd_days}"
                  }
                },
                {
                  "$project": {
                    "id": 1,
                    "code": 1,
                    "discount-rate": 1,
                    "days-for-discount-payment": 1
                  }
                }
              ]
            },
            {
              "aggregate": [
                {
                  "$match": {
                    "type": "DaysAfterNetPaymentTerm",
                    "active": true,
                    "days-for-discount-payment": {
                      "$ne": null
                    }
                  }
                },
                {
                  "$project": {
                    "id": 1,
                    "code": 1,
                    "discount-rate": 1,
                    "days-for-discount-payment": 1
                  }
                }
              ]
            }
          ]
        },
        "default": {
          "label": "---",
          "value": ""
        },
        "mapping": {
          "label_keys": [
            "code"
          ],
          "dataset_key": "id",
          "target_schema_id": "epd_payment_terms_match"
        },
        "result_actions": {
          "no_match_found": {
            "select": "default"
          },
          "one_match_found": {
            "select": "best_match"
          },
          "multiple_matches_found": {
            "select": "default"
          }
        },
        "action_condition": "'{epd_detected}' == 'true'",
        "additional_mappings": [
          {
            "dataset_key": "days-for-discount-payment",
            "target_schema_id": "epd_payment_terms_days_match"
          },
          {
            "dataset_key": "code",
            "target_schema_id": "epd_payment_terms_code_match"
          },
          {
            "dataset_key": "discount-rate",
            "target_schema_id": "epd_payment_terms_rate_match"
          }
        ]
      }
    ]
  },
  "active": true,
  "events": [
    "annotation_content.initialize",
    "annotation_content.started",
    "annotation_content.updated"
  ],
  "queues": [
    "https://cib.rossum.app/api/v1/queues/1260377",
    "https://cib.rossum.app/api/v1/queues/1260388"
  ],
  "run_after": [
    "https://cib.rossum.app/api/v1/hooks/343051"
  ],
  "metadata": {},
  "config": {
    "private": true,
    "schedule": {},
    "app": null,
    "payload_logging_enabled": false,
    "timeout_s": 60,
    "max_polling_time_s": 300,
    "retry_count": 4,
    "retry_after_polling_failure": true,
    "insecure_ssl": false,
    "client_ssl_certificate": null,
    "retry_on_any_non_2xx": false
  },
  "test": {},
  "sideload": [
    "schemas"
  ],
  "settings_schema": null,
  "secrets_schema": {
    "type": "object",
    "properties": {},
    "additionalProperties": {
      "type": "string"
    }
  },
  "token_owner": "https://cib.rossum.app/api/v1/users/282705",
  "extension_source": "rossum_store",
  "guide": "<div>\r\n    <p>To manage and configure the behavior, use our configurator below.</p> \r\n    <p>Start by</p>\r\n    <ul>\r\n        <li>Selecting the queues that you want to use for this extension below</li>\r\n    </ul>\r\n    <p>Then open Master Data Hub and</p>\r\n    <ul>\r\n        <li>Import the dataset with Dataset Management</li>\r\n        <li>Create and set up a new configuration in Configurator</li>\r\n    </ul>\r\n    <p>For more information, take a look at our documentation <a href=\"https://rossum.ai/help/article/master-data-hub-extension\" target=\"_blank\">here</a>.</p>\r\n\r\n    <p><form action=\"https://cib.rossum.app/svc/master-data-hub/web/\" target=\"_blank\" rel=\"noopener noreferrer\">\r\n        <button type=\"submit\"style=\"\r\n            border: none;    \r\n            background: var(--color-primary);\r\n            border-radius: 4px;\r\n            padding: 6px 16px;\r\n            color: var(--white);\r\n            font-weight: 500;\"\r\n         >\r\n            Open configurator\r\n        </button>\r\n    </form></p>\r\n</div>",
  "read_more_url": "https://elis.rossum.ai/svc/master-data-hub/api/docs",
