{
  "id": 540278,
  "type": "webhook",
  "name": "MDH - Tax Codes (CIB)",
  "url": "https://cib.rossum.app/api/v1/hooks/540278",
  "description": "Enhance the extracted data with details from your master records.",
  "settings": {
    "configurations": [
      {
        "name": "Tax Codes (line-items)",
        "source": {
          "dataset": "tax_codes_test",
          "queries": [
            {
              "//": "Memorized value recalled by exact matching supplier_match, recipient_match & item_description, , than union with other results",
              "aggregate": [
                {
                  "$match": {
                    "_id": "#"
                  }
                },
                {
                  "$unionWith": {
                    "coll": "_tax_code_memorization",
                    "pipeline": [
                      {
                        "$match": {
                          "sender_match": "{sender_match}",
                          "recipient_match": "{recipient_match}",
                          "line_item.item_description": "{item_description}"
                        }
                      },
                      {
                        "$lookup": {
                          "as": "original",
                          "from": "tax_codes_test",
                          "localField": "line_item.item_tax_code_match",
                          "foreignField": "id"
                        }
                      },
                      {
                        "$match": {
                          "$expr": {
                            "$gt": [
                              {
                                "$size": "$original"
                              },
                              0
                            ]
                          }
                        }
                      },
                      {
                        "$replaceRoot": {
                          "newRoot": {
                            "$mergeObjects": [
                              {
                                "$arrayElemAt": [
                                  "$original",
                                  0
                                ]
                              },
                              "$$ROOT"
                            ]
                          }
                        }
                      },
                      {
                        "$project": {
                          "id": 1,
                          "code": 1,
                          "active": 1,
                          "memorized": "True",
                          "percentage": 1,
                          "_sortPriority": "1"
                        }
                      }
                    ]
                  }
                },
                {
                  "$match": {
                    "active": true
                  }
                },
                {
                  "$limit": 1
                },
                {
                  "$unionWith": {
                    "coll": "tax_codes_test",
                    "pipeline": [
                      {
                        "$facet": {
                          "pipeline1Results": [
                            {
                              "$match": {
                                "active": true,
                                "percentage": "{item_rate_calculated}",
                                "country.code": "{recipient_country_code_match}"
                              }
                            }
                          ],
                          "pipeline2Results": [
                            {
                              "$match": {
                                "active": true,
                                "percentage": "{item_rate_calculated}",
                                "country.code": "{recipient_entity_country_code_match}"
                              }
                            }
                          ],
                          "pipeline3Results": [
                            {
                              "$match": {
                                "active": true,
                                "percentage": "{item_rate_calculated}"
                              }
                            }
                          ]
                        }
                      },
                      {
                        "$project": {
                          "result": {
                            "$cond": {
                              "if": {
                                "$gt": [
                                  {
                                    "$size": "$pipeline1Results"
                                  },
                                  0
                                ]
                              },
                              "else": {
                                "$cond": {
                                  "if": {
                                    "$gt": [
                                      {
                                        "$size": "$pipeline2Results"
                                      },
                                      0
                                    ]
                                  },
                                  "else": "$pipeline3Results",
                                  "then": "$pipeline2Results"
                                }
                              },
                              "then": "$pipeline1Results"
                            }
                          }
                        }
                      },
                      {
                        "$unwind": {
                          "path": "$result"
                        }
                      },
                      {
                        "$project": {
                          "id": "$result.id",
                          "code": "$result.code",
                          "percentage": "$result.percentage",
                          "_sortPriority": "3"
                        }
                      }
                    ]
                  }
                },
                {
                  "$facet": {
                    "emptyDocument": [
                      {
                        "$group": {
                          "_id": null,
                          "count": {
                            "$sum": 1
                          },
                          "memorizedCount": {
                            "$sum": {
                              "$cond": [
                                {
                                  "$ne": [
                                    {
                                      "$type": "$memorized"
                                    },
                                    "missing"
                                  ]
                                },
                                1,
                                0
                              ]
                            }
                          }
                        }
                      },
                      {
                        "$match": {
                          "count": {
                            "$gt": 1
                          },
                          "memorizedCount": 0
                        }
                      },
                      {
                        "$replaceWith": {
                          "id": "",
                          "code": "---",
                          "percentage": "",
                          "_sortPriority": "2"
                        }
                      }
                    ],
                    "originalDocuments": []
                  }
                },
                {
                  "$project": {
                    "combinedResults": {
                      "$concatArrays": [
                        "$originalDocuments",
                        "$emptyDocument"
                      ]
                    }
                  }
                },
                {
                  "$unwind": "$combinedResults"
                },
                {
                  "$replaceWith": "$combinedResults"
                },
                {
                  "$sort": {
                    "_sortPriority": 1
                  }
                },
                {
                  "$group": {
                    "_id": {
                      "id": "$id",
                      "code": "$code",
                      "percentage": "$percentage"
                    },
                    "originalDoc": {
                      "$first": "$$ROOT"
                    }
                  }
                },
                {
                  "$replaceRoot": {
                    "newRoot": "$originalDoc"
                  }
                },
                {
                  "$sort": {
                    "_sortPriority": 1
                  }
                }
              ]
            }
          ]
        },
        "default": {
          "label": "---",
          "value": ""
        },
        "mapping": {
          "dataset_key": "id",
          "label_template": "{code}, {percentage || '---'}",
          "target_schema_id": "item_tax_code_match"
        },
        "result_actions": {
          "no_match_found": {
            "select": "default"
          },
          "one_match_found": {
            "select": "best_match"
          },
          "multiple_matches_found": {
            "select": "best_match"
          }
        }
      },
      {
