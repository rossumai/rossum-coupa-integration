{
  "id": 735955,
  "type": "webhook",
  "name": "MDH - Coupa Invoice Check (CIB)",
  "url": "https://cib.rossum.app/api/v1/hooks/735955",
  "description": "Enhance the extracted data with details from your master records.",
  "settings": {
    "configurations": [
      {
        "name": "Coupa Invoice Existence Check",
        "source": {
          "auth": {
            "url": "{oauth_url}",
            "body": {
              "scope": "core.invoice.read",
              "client_id": "ef7262b7624a011ec6eb1178c28e1a0b",
              "grant_type": "client_credentials",
              "client_secret": "{secrets.client_secret}"
            },
            "method": "POST",
            "headers": {
              "Accept": "application/json",
              "Content-Type": "application/x-www-form-urlencoded"
            }
          },
          "queries": [
            {
              "url": "{create_draft_url}",
              "body": {},
              "method": "GET",
              "headers": {
                "Accept": "application/json",
                "Authorization": "Bearer {auth.body.access_token}"
              },
              "result_path": "",
              "query_params": {
                "fields": "[\"id\",\"status\"]",
                "supplier_id": "{sender_export}",
                "invoice_number": "{document_id_manual}"
              }
            }
          ]
        },
        "default": {
          "label": "---",
          "value": ""
        },
        "mapping": {
          "dataset_key": "status",
          "target_schema_id": "duplicate_invoice_statuses"
        },
        "result_actions": {
          "no_match_found": {
            "message": {
              "type": "info",
              "content": "No duplicates found"
            }
          },
          "one_match_found": {
            "select": "best_match"
          },
          "multiple_matches_found": {
            "select": "best_match",
            "message": {
              "type": "info",
              "content": "Multiple duplicate statuses found"
            }
          }
        }
      }
    ]
  },
  "active": true,
  "events": [
    "annotation_content.initialize",
    "annotation_content.started",
    "annotation_content.updated"
  ],
  "queues": [
    "https://cib.rossum.app/api/v1/queues/1260377",
    "https://cib.rossum.app/api/v1/queues/1260388"
  ],
  "run_after": [
    "https://cib.rossum.app/api/v1/hooks/343051"
  ],
  "metadata": {},
  "config": {
    "private": true,
    "schedule": {},
    "app": null,
    "payload_logging_enabled": false,
    "timeout_s": 60,
    "max_polling_time_s": 300,
    "retry_count": 4,
    "retry_after_polling_failure": true,
    "insecure_ssl": false,
    "client_ssl_certificate": null,
    "retry_on_any_non_2xx": false
  },
  "test": {},
  "sideload": [
