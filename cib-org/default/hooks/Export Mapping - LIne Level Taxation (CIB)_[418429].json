{
  "id": 418429,
  "type": "webhook",
  "name": "Export Mapping - LIne Level Taxation (CIB)",
  "url": "https://cib.rossum.app/api/v1/hooks/418429",
  "description": "",
  "settings": {
    "export_configs": [
      {
        "content_encoding": "utf-8",
        "export_reference_key": "create_draft",
        "file_content_template_multiline": [
          "{",
          " \"taggings\": [",
          "   {",
          "     \"tag\": {",
          "       \"name\":\"{{ field.rossum_tag }}\"",
          "     }",
          "   }",
          "   {% if payload['annotation']['automated'] == true %}",
          "   ,{",
          "     \"tag\": {",
          "       \"name\":\"rossum_automated\"",
          "     }",
          "   }",
          "   {% endif %}",
          "  ],",
          "  \"currency\": {",
          "   \"code\":\"{{ field.currency }}\"",
          "  },",
          "  \"supplier\": {",
          "   \"id\":\"{{ field.sender_export }}\"",
          "  },",
          "  \"supplier-total\": {{ field.amount_total | default(0,true) }},",
          "  {% if field.document_type == \"credit_note\" %}",
          "  \"document-type\": \"Credit Note\",",
          "  {% else %}",
          "  \"document-type\": \"Invoice\",",
          "  {% endif %}",
          "  \"gross-total\": \"{{ field.amount_total | default(0,true) }}\",",
          "  \"account-type\": {",
          "   \"id\":\"{{ field.recipient_export }}\"",
          "  },",
          "  {% if field.recipient_ship_to_match != \"\" %}",
          "     \"ship-to-address\": {",
          "       \"id\":\"{{ field.recipient_ship_to_match }}\"",
          "     },",
          "  {% endif %}",
          "  {% if field.backing_document == \"contract\" %}",
          "     \"contract\": {",
          "       \"number\":\"{{ field.contract_match }}\"",
          "     },",
          "  {% endif %}",
          "  {% if field.requestor_email != \"\" %}",
          "     \"requester-email\": \"{{ field.requestor_email }}\",",
          "  {% elif field.requestor_email_calculated != \"\" %}",
          "     \"requester-email\": \"{{ field.requestor_email_calculated }}\",",
          "  {% endif %}",
          "  \"invoice-date\": \"{{ field.date_issue_manual }}\",",
          "  \"invoice-number\": \"{{ field.document_id_manual }}\",",
          "  {% if field.payment_terms_export != \"\" %}",
          "     \"payment-term\": {",
          "       \"id\":\"{{ field.payment_terms_export }}\"",
          "     },",
          "  {% endif %}",
          "  \"total-with-taxes\": \"{{ field.amount_total | default(0,true) }}\",",
          "  \"line-level-taxation\": true,",
          "  \"original-invoice-date\": \"{{ field.original_date_issue }}\",",
          "  \"original-invoice-number\": \"{{ field.original_document_id }}\",",
          "  {% if field.document_type == \"credit_note\" %}",
          "   \"is-credit-note\": \"true\",",
          "  {% else %}",
          "  \"is-credit-note\": \"false\",",
          "  {% endif %}",
          "  \"invoice-charges\": [",
          "  {",
          "   \"type\": \"InvoiceShippingCharge\",",
          "   \"total\": {{ field.charges_net_amount_total_calculated }},",
          "   \"currency\": {",
          "     \"code\":\"{{ field.currency }}\"",
          "   },",
          "   \"line-num\": 1,",
          "   \"tax-lines\": {",
          "     \"tax-line\": {",
          "       \"type\":\"TaxLine\",",
          "       \"amount\":\"{{ field.charges_total_tax_calculated }}\",",
          "       \"rate\":\"{{ field.charges_tax_rate_average_calculated }}\"",
          "     }",
          "   },",
          "   \"accounting-total\": \"{{ field.charges_net_amount_total_calculated }}\"",
          "  }",
          "  ],",
          "  \"invoice-lines\": [",
          "  {% for item in field.line_items %}{",
          "   \"uom\": {",
          "     \"code\":\"{{ item.item_uom_export }}\"",
          "   },",
          "   \"price\": {{ item.item_price_export | default(0,true) }},",
          "   \"currency\": {",
          "     \"code\":\"{{ field.currency }}\"",
          "   },",
          "   \"start-date\": \"{{ item.sp_item_start_date_export }}\",",
          "   \"end-date\": \"{{ item.sp_item_end_date_export }}\",",
          "   \"type\": \"{{ item.item_line_type }}\",",
          "   \"quantity\": \"{{ item.item_quantity_export }}\",",
          "   \"po-number\": \"{{ item.item_order_id_calculated }}\",",
          "   \"description\": {{ item.item_description_export | tojson }},",
          "   \"order-line-num\": \"{{ item.item_po_line_number_match }}\",",
          "   \"order-header-num\": \"{{ item.item_order_id_calculated }}\",",
          "   \"tax-lines\": {",
          "     \"tax-line\": {",
          "       \"type\":\"TaxLine\",",
          "       \"amount\":\"{{ item.item_tax_calculated }}\",",
          "       \"rate\":\"{{ item.item_rate_calculated }}\"",
          "       {% if item.item_tax_code_match != \"\" %}",
          "         ,\"tax-code\": {",
          "           \"id\":\"{{ item.item_tax_code_match }}\"",
          "         }",
          "       {% endif %}",
          "     }",
          "   }",
          "  }{% if not loop.last %},{% endif %}",
          "  {% else %}",
          "  {",
          "   \"uom\": {",
          "     \"code\":\"{{ field.uom_export }}\"",
          "   },",
          "   \"price\": {{ field.price_export | default(0,true) }},",
          "   \"currency\": {",
          "     \"code\":\"{{ field.currency }}\"",
          "   },",
          "   \"start-date\": \"{{ field.service_period_start_export }}\",",
          "   \"end-date\": \"{{ field.service_period_end_export }}\",",
          "   \"type\": \"{{ field.line_type }}\",",
          "   \"quantity\": \"{{ field.quantity_export }}\",",
          "   \"po-number\": \"{{ field.order_id_calculated }}\",",
          "   \"description\": {{ field.description_export | tojson}},",
          "   \"order-line-num\": \"{{ field.po_line_number_match }}\",",
          "   \"order-header-num\": \"{{ field.order_id_calculated }}\",",
          "   \"tax-lines\": {",
          "     \"tax-line\": {",
          "       \"type\":\"TaxLine\",",
          "       \"amount\":\"{{ field.amount_total_tax_calculated }}\",",
          "       \"rate\":\"{{ field.tax_rate_calculated }}\"",
          "       {% if field.tax_code_match != \"\" %}",
          "         ,\"tax-code\": {",
          "           \"id\":\"{{ field.tax_code_match }}\"",
          "         }",
          "       {% endif %}",
          "     }",
          "   }",
          "   }",
          "  {% endfor %}]",
          "}"
        ]
      }
    ]
  },
  "active": true,
  "events": [
    "annotation_content.export"
  ],
  "queues": [
    "https://cib.rossum.app/api/v1/queues/1260377"
  ],
  "run_after": [],
  "metadata": {},
  "config": {
    "schedule": {
      "cron": ""
    },
    "app": null,
    "payload_logging_enabled": false,
    "timeout_s": 30,
